---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (d: Date) => d.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title="Sleep Token / Analyses">
  <section style="margin-bottom: 4rem;">
    <p style="font-size: 1.15rem; color: var(--text-muted); font-style: italic;">
      Analyses longues sur Sleep Token. Lectures business, cycles d'album, rapport au mythe.
      Pas d'actualité brève, pas de lyrics, pas de pochettes officielles. Juste de la prose et de la pensée.
    </p>
    <p style="color: var(--text-faint); font-size: 0.9rem;">
      Publié quand l'envie vient. Pas de calendrier, pas de newsletter — discussions sur le
      <a href="https://discord.gg/REMPLACE_PAR_TON_INVITE" target="_blank" rel="noopener">Discord</a>.
    </p>
  </section>

  <ul class="post-list">
    {posts.map((post) => (
      <li class="post-card">
        <a href={`${import.meta.env.BASE_URL}/posts/${post.slug}/`}>
          <div class="meta">
            {post.data.era && <span>{post.data.era} · </span>}
            <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
          </div>
          <h2>{post.data.title}</h2>
          <p class="description">{post.data.description}</p>
        </a>
      </li>
    ))}
  </ul>

  {posts.length === 0 && (
    <p style="color: var(--text-faint); text-align: center; padding: 3rem 0;">
      Pas encore d'articles publiés. Bientôt.
    </p>
  )}
</BaseLayout>
